{
  "name": "@bytezhang/ledger-adapter",
  "version": "0.0.36",
  "description": "Ledger hardware wallet adapter for OneKey",
  "author": "OneKey",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./web": {
      "import": "./dist/entries/web.mjs",
      "require": "./dist/entries/web.js"
    },
    "./react-native": {
      "import": "./dist/entries/react-native.mjs",
      "require": "./dist/entries/react-native.js"
    },
    "./node": {
      "import": "./dist/entries/node.mjs",
      "require": "./dist/entries/node.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "test": "vitest run"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OneKeyHQ/hardware-wallet-kit.git",
    "directory": "packages/ledger-adapter"
  },
  "keywords": [
    "ledger",
    "hardware-wallet",
    "onekey",
    "crypto"
  ],
  "dependencies": {
    "@bytezhang/hardware-wallet-core": "0.0.36",
    "@ledgerhq/context-module": "^1.0.0",
    "@ledgerhq/device-management-kit": "^1.1.0",
    "@ledgerhq/device-signer-kit-ethereum": "^1.9.0",
    "@ledgerhq/device-signer-kit-bitcoin": "^1.0.0",
    "@ledgerhq/device-signer-kit-solana": "^1.7.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "rimraf": "^5.0.0"
  }
}
