{
  "name": "@bytezhang/hardware-trezor-adapter",
  "version": "0.0.32",
  "description": "Trezor hardware wallet adapter for OneKey",
  "author": "OneKey",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rimraf dist",
    "lint": "eslint src --ext .ts",
    "test": "echo \"No tests yet\""
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/OneKeyHQ/hardware-wallet-kit.git",
    "directory": "packages/trezor-adapter"
  },
  "keywords": [
    "trezor",
    "hardware-wallet",
    "onekey",
    "crypto"
  ],
  "dependencies": {},
  "devDependencies": {
    "rimraf": "^5.0.0"
  }
}
